<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Required for Flutter hot reload and debugging tools -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!--
        Разрешает HTTP только в debug-сборках — для локальной разработки
        (http://192.168.x.x:8088). В release-сборке HTTPS обязателен.
    -->
    <application android:usesCleartextTraffic="true"/>
</manifest>
